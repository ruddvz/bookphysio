# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay (currently disabled — wired for future subscription billing)
# RAZORPAY_KEY_ID=rzp_live_xxxx
# RAZORPAY_KEY_SECRET=your-secret
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Resend (email)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@bookphysio.in

# SMS / Phone OTP
# Phone OTP is delivered by Supabase Auth via a Send SMS Hook + Edge Function → MSG91.
# MSG91 is NOT a built-in Supabase SMS provider dropdown.
# See docs/MSG91-SETUP-GUIDE.md for the complete setup walkthrough.
# No app-side SMS env vars are required for OTP.

# MSG91 Transactional SMS & WhatsApp (appointment reminders, booking confirmations)
# Required for SMS notifications; WhatsApp is optional.
MSG91_AUTH_KEY=
MSG91_SMS_SENDER_ID=BKPHYS
MSG91_SMS_TEMPLATE_REMINDER=
MSG91_SMS_TEMPLATE_CONFIRM=
MSG91_SMS_TEMPLATE_RESCHEDULE=
# Optional: WhatsApp Business number for WhatsApp notifications
# MSG91_WHATSAPP_INTEGRATED_NUMBER=

# Upstash (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://bookphysio.in
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key

# Admin email for daily AI summary reports
ADMIN_EMAIL=admin@bookphysio.in

# Vercel Cron secret — used to authenticate scheduled cron job requests
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Optional IndexNow override for scripts/ping-indexnow.mjs.
# Leave unset to use the hosted public key file instead.
# INDEXNOW_KEY=9e3b426a8d844146a2ee1fac2c3fc665

# Preview access (shared password for /preview page on live site)
# Set to any strong password — share URL + password with testers
# REQUIRED in production if ENABLE_PUBLIC_PREVIEW_GATE=true — no hardcoded fallback
PREVIEW_PASSWORD=

# Public preview gate switch for production
# Must be explicitly set to 'true' to enable the /preview page and /api/auth/preview
# Defaults to DISABLED — set to 'true' only when intentionally sharing preview access
ENABLE_PUBLIC_PREVIEW_GATE=

# Preview token signing secret
# REQUIRED when ENABLE_PUBLIC_PREVIEW_GATE=true (unless DEMO_COOKIE_SECRET is already set)
# Generate with: openssl rand -base64 32
PREVIEW_TOKEN_SECRET=

# Demo cookie signing secret
# REQUIRED in all environments where demo mode (NEXT_PUBLIC_ENABLE_DEMO=true) is used
# No hardcoded fallback — missing secret causes demo cookies to fail gracefully
# Generate with: openssl rand -base64 32
DEMO_COOKIE_SECRET=

# Pending OTP cookie signing secret
# Used to keep raw mobile numbers out of client-side storage during OTP verify flows
# Generate with: openssl rand -base64 32
OTP_PENDING_COOKIE_SECRET=
