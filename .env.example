# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay (currently disabled — wired for future subscription billing)
# RAZORPAY_KEY_ID=rzp_live_xxxx
# RAZORPAY_KEY_SECRET=your-secret
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Resend (email)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@bookphysio.in

# Textbelt (SMS OTP delivery)
# Free: leave empty or set to 'textbelt' (1 SMS/day for testing)
# Paid: get a key from https://textbelt.com/ (~$0.01/SMS, India supported)
TEXTBELT_API_KEY=textbelt

# Upstash (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://bookphysio.in
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key

# Optional IndexNow override for scripts/ping-indexnow.mjs.
# Leave unset to use the hosted public key file instead.
# INDEXNOW_KEY=9e3b426a8d844146a2ee1fac2c3fc665

# Preview access (shared password for /preview page on live site)
# Set to any strong password — share URL + password with testers
# Leave unset in production to disable preview access entirely
PREVIEW_PASSWORD=

# Demo cookie signing secret (separate from PREVIEW_PASSWORD)
# Required in all environments where demo mode is used
# Generate with: openssl rand -base64 32
DEMO_COOKIE_SECRET=
