# bookphysio.in — environment variables
#
# Every key listed below with `# REQUIRED` is validated at build time by
# `scripts/check-env.mjs` (runs automatically via the `prebuild` hook).
# Run `npm run check:env` at any time to verify your local setup.
#
# Never commit this file with real values — copy to `.env.local` for dev,
# and set production values in the Vercel dashboard.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co       # REQUIRED
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key                     # REQUIRED
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key                 # REQUIRED (server-only)

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000                       # REQUIRED (runtime origin)
NEXT_PUBLIC_SITE_URL=https://bookphysio.in                      # REQUIRED (canonical for SEO)

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxx                                          # REQUIRED
RESEND_FROM_EMAIL=noreply@bookphysio.in                         # REQUIRED (verified sender)

# ─── MSG91 (transactional SMS + WhatsApp) ────────────────────────────────────
# Phone-OTP delivery is handled by Supabase Auth → Supabase Edge Function → MSG91
# (configured in the Supabase dashboard). These vars are for app-side sends
# (reminders, confirmations, reschedules).
MSG91_AUTH_KEY=                                                 # REQUIRED
MSG91_SMS_SENDER_ID=BKPHYS                                      # REQUIRED (DLT-registered sender)
MSG91_SMS_TEMPLATE_REMINDER=                                    # REQUIRED (DLT template id)
MSG91_SMS_TEMPLATE_CONFIRM=                                     # REQUIRED (DLT template id)
MSG91_SMS_TEMPLATE_RESCHEDULE=                                  # REQUIRED (DLT template id)
# MSG91_WHATSAPP_INTEGRATED_NUMBER=                             # OPTIONAL (enables WhatsApp)

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io               # REQUIRED
UPSTASH_REDIS_REST_TOKEN=your-token                             # REQUIRED

# ─── Google Generative AI (Gemini) ───────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-api-key  # REQUIRED

# ─── Cron + admin ────────────────────────────────────────────────────────────
# Generate CRON_SECRET with: openssl rand -hex 32
CRON_SECRET=                                                    # REQUIRED
ADMIN_EMAIL=admin@bookphysio.in                                 # REQUIRED (daily summary recipient)

# ─── Auth cookie secrets ─────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 32
OTP_PENDING_COOKIE_SECRET=                                      # REQUIRED

# ─── Preview gate (shared-password access to /preview) ───────────────────────
# All three vars below are REQUIRED only when ENABLE_PUBLIC_PREVIEW_GATE=true.
ENABLE_PUBLIC_PREVIEW_GATE=                                     # OPTIONAL (set to 'true' to enable)
PREVIEW_PASSWORD=                                               # conditional
PREVIEW_TOKEN_SECRET=                                           # conditional (or reuse DEMO_COOKIE_SECRET)

# ─── Demo mode (in-app patient/provider/admin walkthrough) ───────────────────
NEXT_PUBLIC_ENABLE_DEMO=                                        # OPTIONAL (set to 'true' to enable)
DEMO_COOKIE_SECRET=                                             # conditional (REQUIRED when demo mode is on)
DEMO_ADMIN_FALLBACK_ENABLED=false                               # Set 'true' only in demo/staging; NEVER in production

# ─── Razorpay (currently archived — payments temporarily disabled) ───────────
# Uncomment + populate when subscription billing is re-enabled.
# RAZORPAY_KEY_ID=rzp_live_xxxx
# RAZORPAY_KEY_SECRET=your-secret
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ─── IndexNow (SEO ping script override) ─────────────────────────────────────
# Leave unset to use the hosted public key file.
# INDEXNOW_KEY=

# ─── Auth email OTP ───────────────────────────────────────────────────────────
# 32-byte hex HMAC secret for hashing 6-digit OTP codes before storing in DB.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED for doctor-signup email verification.
EMAIL_OTP_SECRET=

# ─── Admin notifications ──────────────────────────────────────────────────────
# Email address that receives new provider application alerts.
ADMIN_ALERT_EMAIL=
